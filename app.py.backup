            border: 2px solid var(--border-soft) !important;
        }
        
        .footer p {
            color: white !important;
        }
    }
    
    /* ===== LIGHT THEME - BRAND NEW, COMPLETELY SEPARATE ===== */
    @media (prefers-color-scheme: light) {
        /* Main app background - pure white */
        .stApp {
