    }
    
    /* ===== LIGHT THEME - BRAND NEW, COMPLETELY SEPARATE ===== */
    @media (prefers-color-scheme: light) {
        /* Main app background - pure white */
        .stApp {
            background: #ffffff !important;
        }
        
        /* ALL text black */
